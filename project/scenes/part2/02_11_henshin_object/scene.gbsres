          {
            "command": "EVENT_TEXT",
            "args": {
              "text": [
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!HA!",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!This is funnier\nin spanish...",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!This will give \nyou one of my \npowers",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!Maybe it's not \nwhat it was \nbefore.",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!But, if we \ncombine our \npowers,",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!We might be \nable to \nsucceed!",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!This will turn \nyou into your \n!F:1b486c36-f724-4b74-9b2e-e0f1e9321da3!true self!"
              ],
              "__section": "text",
              "avatarId": "46613d9a-8ba8-4a93-9569-52d60e990798",
              "minHeight": 4,
              "maxHeight": 7,
              "textX": 2,
