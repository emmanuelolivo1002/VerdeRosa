          }
        ],
        "false": [
          {
            "command": "EVENT_TEXT",
            "args": {
              "text": [
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!¡Con esto \ntienes!",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!Este es el \nHENSHINADOR"
              ],
              "__section": "text",
