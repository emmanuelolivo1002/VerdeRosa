          {
            "command": "EVENT_TEXT",
            "args": {
              "text": [
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!¡JUAS JUAS!",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!¡Se pronuncia\nJENSHINADOR!",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!Esto te dará \nuna de mis \nhabilidades",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!Tal vez ya no \nsea lo que era \nantes",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!Pero a lo mejor\ny combinando ",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!nuestro poder \njuntos, esto \npodrá salir.",
                "!F:0bf3fa9c-c924-4f50-8fdf-52ec75fc0c89!Esto te \nconvertirá en \ntu !F:1b486c36-f724-4b74-9b2e-e0f1e9321da3!verdadero yo"
              ],
              "__section": "text",
