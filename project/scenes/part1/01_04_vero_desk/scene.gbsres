      "children": {
        "true": [
          {
            "command": "EVENT_TEXT",
            "args": {
              "text": [
                "It is clear that \nfor humans,",
                "Death is imminent.",
                "Always keeping \nthis in mind:",
                "\"There is no \nworse punishment ",
                "Than leaving this \nworld alone.\"",
                "Yet in my days \non earth,",
                "I live fighting \nanother war",
                "Against what I \ncannot control:",
                "I do not fear \ndying alone...",
                "It is living it \nwhat terrifies me."
              ],
              "__section": "text",
              "avatarId": "",
              "minHeight": 4,
              "maxHeight": 7,
              "textX": 1,
              "textY": 1,
              "textHeight": 5,
              "position": "top",
