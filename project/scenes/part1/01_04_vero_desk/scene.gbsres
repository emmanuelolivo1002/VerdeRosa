              "closeDelayFrames": 30,
              "__collapse": true
            },
            "id": "e0774d26-3cad-499b-bd0d-50ec397cfb61"
          }
        ],
        "false": [
          {
            "command": "EVENT_TEXT",
            "args": {
              "text": [
                "Evidente es que \nal humano",
                "La muerte llega \ninminente",
                "Llevando esto \nsiempre en mente:",
                "\"No hay castigo \nmás tirano",
                "Que irse con nadie\na la mano\"",
                "Más mis días en la\ntierra",
                "Vivo luchando otra\nguerra",
                "Contra lo que no \ncontrolo:",
                "No le temo a \nmorir solo...",
                "Vivirlo es lo que \nme aterra"
              ],
              "__section": "text",
