          {
            "command": "EVENT_TEXT_DRAW",
            "args": {
              "text": "!F:c38c5c88-d25a-4c03-961f-96023b78359e!She uses her phone\nall night.\nIn her privacy she\nuses the dating app,\n!F:2bbe3caf-3218-4df8-9161-94cdc7088b59!FINDER",
