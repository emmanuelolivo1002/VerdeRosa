          }
        ],
        "false": [
          {
            "command": "EVENT_TEXT_DRAW",
            "args": {
              "text": "!F:c38c5c88-d25a-4c03-961f-96023b78359e!Usa su teléfono \ntoda la noche.\nEn su privacidad,\nusa la app de \ncitas, !F:2bbe3caf-3218-4df8-9161-94cdc7088b59!FINDER",
              "x": 1,
